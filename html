<!DOCTYPE html>
<html>
<head>
<title>AI YT BOT</title>
</head>

<body style="background:black;color:white;text-align:center">

<h1>🔥 AI YOUTUBE BOT</h1>

<button onclick="generate()">Generate Video</button>

<p id="output"></p>

<script>
async function generate(){

let prompt = "Give 1 viral emotional youtube shorts script 30 sec";

let res = await fetch("https://api.openai.com/v1/chat/completions", {
method:"POST",
headers:{
"Content-Type":"application/json",
"Authorization":"Bearer YOUR_API_KEY"
},
body:JSON.stringify({
model:"gpt-4o-mini",
messages:[{role:"user",content:prompt}]
})
});

let data = await res.json();

let script = data.choices[0].message.content;

document.getElementById("output").innerText = script;

// आगे तुम यही script voice + video में use करोगे
}
</script>

</body>
</html>

